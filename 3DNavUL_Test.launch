<launch>
  <!-- map&odom -->
  <arg name="map"         default="RMUL2026.yaml" />
  <arg name="globalmap_pcd" default="RMUL2026.pcd" />
  <arg name="init_pos_x"   default="10.107939720153809" />
  <arg name="init_pos_y"   default="-4.187480926513672" />
  <arg name="init_pos_z"   default="0.0" />
  <arg name="init_ori_w"   default="0.05464960747042481" />
  <arg name="init_ori_x"   default="0.0" />
  <arg name="init_ori_y"   default="0.0" />
  <arg name="init_ori_z"   default="-0.9985055935763848" />

    <!-- <include file="$(find pcd2pgm)/launch/pcd2pgm.launch" /> -->
    <include file="$(find bot_sim)/launch_real/map_server.launch">
      <arg name="map" value="$(arg map)" />
    </include>
    
    <include file="$(find bot_sim)/launch_real/imu_filter.launch" />
    
    <include file="$(find livox_ros_driver2)/launch_ROS1/msg_mixed.launch" />
    
    <!-- <include file="$(find bot_sim)/launch_real/lidar_merge_pointcloud.launch" /> -->
    
    <include file="$(find hdl_localization)/launch/hdl_localization.launch">
      <arg name="globalmap_pcd" value="$(arg globalmap_pcd)" />
      <arg name="init_pos_x"   value="$(arg init_pos_x)" />
      <arg name="init_pos_y"   value="$(arg init_pos_y)" />
      <arg name="init_pos_z"   value="$(arg init_pos_z)" />
      <arg name="init_ori_w"   value="$(arg init_ori_w)" />
      <arg name="init_ori_x"   value="$(arg init_ori_x)" />
      <arg name="init_ori_y"   value="$(arg init_ori_y)" />
      <arg name="init_ori_z"   value="$(arg init_ori_z)" />
    </include>
    <!-- <include file="$(find hdl_localization)/launch/hdl_localization1.launch" />     -->
    <include file="$(find bot_sim)/launch_real/real_robot_transform.launch" />
    
    <include file="$(find livox_cloudpoint_processor)/launch/lidar_filter_pointcloud.launch" />
    
    <!-- <include file="$(find bot_sim)/launch_real/dbscan_bfs_3D.launch" /> -->
    <include file="$(find bot_sim)/launch_real/dstarlite.launch" />
    
    <include file="$(find bot_sim)/launch_real/ser2msg_tf_decision_givepoint.launch" />

</launch>